generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   // BA | SENIOR_BA | PM
  createdAt    DateTime @default(now())

  createdProjects  Project[]    @relation("ProjectCreator")
  uploadedDocuments Document[] @relation("DocumentAuthor")
  reviewedApprovals Approval[] @relation("ApprovalReviewer")
  aiSessions       AISession[]
}

// ── Projects ──────────────────────────────────────────────────
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  team        String
  status      String   @default("auditing") // approved | auditing | revision
  createdById Int
  createdBy   User     @relation("ProjectCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents Document[]
}

// ── SRS Documents ─────────────────────────────────────────────
model Document {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  version     String   @default("v1.0")
  filePath    String?  // path trong /uploads (null nếu chưa upload file thật)
  authorId    Int
  author      User     @relation("DocumentAuthor", fields: [authorId], references: [id])
  healthScore Int?     // null = chưa audit
  reqCount    Int      @default(0)
  status      String   @default("pending") // pending | auditing | approved | revision
  uploadedAt  DateTime @default(now())

  auditResult AuditResult?
  approval    Approval?
}

// ── Audit Results ─────────────────────────────────────────────
model AuditResult {
  id           Int      @id @default(autoincrement())
  documentId   Int      @unique
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  score        Int
  totalReqs    Int
  issuesCount  Int
  issuesJson   String   // JSON string: [{type, severity, description}]
  auditedAt    DateTime @default(now())
}

// ── Approval Workflow ─────────────────────────────────────────
model Approval {
  id           Int       @id @default(autoincrement())
  documentId   Int       @unique
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  submittedById Int
  reviewedById  Int?
  reviewedBy    User?    @relation("ApprovalReviewer", fields: [reviewedById], references: [id])
  status        String   @default("pending") // pending | approved | rejected
  notes         String?
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
}

// ── AI Workspace Sessions ─────────────────────────────────────
model AISession {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      String    @default("create") // create | audit
  title     String    @default("New Session")
  projectId Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages AIMessage[]
}

// ── AI Messages ───────────────────────────────────────────────
model AIMessage {
  id        Int       @id @default(autoincrement())
  sessionId Int
  session   AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String    // user | ai
  content   String    // HTML content (outerHTML of chat bubble)
  createdAt DateTime  @default(now())
}
