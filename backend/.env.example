# ── Database ─────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AI Provider ──────────────────────────────────────────────
# dev:    AI_PROVIDER=lmstudio  (requires LM Studio running locally)
# deploy: AI_PROVIDER=gemini    (free tier, recommended)
#         AI_PROVIDER=openai    (paid)
AI_PROVIDER=lmstudio
AI_BASE_URL=http://localhost:1234
AI_MODEL=reelicit_-_zephyr-7b-beta-reqbrain

# For Gemini / OpenAI (only needed when AI_PROVIDER != lmstudio)
# AI_API_KEY=your_api_key_here

# ── Frontend ─────────────────────────────────────────────────
# CORS whitelist (add your deployed frontend URL here)
FRONTEND_URL=http://localhost:5500

# Set to "true" to let the backend serve the frontend HTML files
# (use this when NOT running VS Code Live Server)
SERVE_FRONTEND=false
